{
  "name": "stemdrop-ableton",
  "productName": "StemDrop",
  "version": "0.1.0",
  "description": "Lokaler MVP-Prototyp zum schnellen Austausch von Audio-Dateien waehrend einer Ableton-Session.",
  "private": true,
  "type": "module",
  "main": "electron-app/main.js",
  "author": "StemDrop",
  "scripts": {
    "start": "node server/ws-server.js",
    "demo": "node server/demo.js",
    "watch": "node server/watch.js",
    "analyze": "node server/analyze.js",
    "server": "node server/ws-server.js",
    "helper": "node server/local-helper-api.js",
    "client": "node client/local-client.js",
    "dev:helper": "node server/local-helper-api.js",
    "dev:client": "node client/local-client.js",
    "dev:render-client": "STEMDROP_SERVER_IP=wss://stemdrop-relay.onrender.com node client/local-client.js",
    "test:relay": "node client/simulate-transfer.js",
    "history": "node server/history.js",
    "simulate": "node client/simulate-transfer.js",
    "gui": "node electron-app/run-gui.js",
    "build": "ELECTRON_CACHE=.npm-cache/electron ELECTRON_BUILDER_CACHE=.npm-cache/electron-builder electron-builder --mac dir",
    "dist": "ELECTRON_CACHE=.npm-cache/electron ELECTRON_BUILDER_CACHE=.npm-cache/electron-builder electron-builder --mac dmg",
    "build:linux": "ELECTRON_CACHE=.npm-cache/electron ELECTRON_BUILDER_CACHE=.npm-cache/electron-builder electron-builder --linux AppImage deb --x64"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "electron": "^34.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.stemdrop.ableton",
    "productName": "StemDrop",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron-app/**/*",
      "client/**/*",
      "server/**/*",
      "shared/.gitkeep",
      "logs/.gitkeep",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.music",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "category": "Audio",
      "maintainer": "StemDrop <stemdrop@example.com>",
      "target": [
        "AppImage",
        "deb"
      ],
      "artifactName": "${productName}-${version}.${ext}"
    }
  }
}
